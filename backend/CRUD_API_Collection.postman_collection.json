          "raw": "{{base_url}}/api/users/99999",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users",
            "99999"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "  pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test('Response has error message', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('error');",
              "  pm.expect(jsonData.error).to.include('not found');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Error - Missing Required Fields",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n  \\\"name\\\": \\\"Test User\\\"\\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 (Bad Request)', function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Response has error about missing email', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('error');",
              "  pm.expect(jsonData.error).to.include('email');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Error - Invalid Email Format",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n  \\\"name\\\": \\\"Test User\\\",\\n  \\\"email\\\": \\\"not-an-email\\\"\\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 (Bad Request)', function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Response indicates invalid email format', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('error');",
              "  pm.expect(jsonData.error.toLowerCase()).to.include('email');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
